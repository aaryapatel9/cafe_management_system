generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Branch {
  id              Int              @id @default(autoincrement())
  name            String           @unique @db.VarChar(120)
  code            String           @unique @db.VarChar(30)
  address         String           @default("")
  phone           String           @default("") @db.VarChar(30)
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamp(6)
  users           User[]
  floors          Floor[]
  tables          RestaurantTable[]
  terminals       POSTerminal[]
  sessions        POSSession[]
  orders          Order[]
  selfOrderTokens SelfOrderToken[]

  @@map("branches")
}

model User {
  id           Int          @id @default(autoincrement())
  branchId     Int?         @map("branch_id")
  name         String       @db.VarChar(120)
  username     String       @unique @db.VarChar(50)
  email        String       @unique @db.VarChar(255)
  passwordHash String       @map("password_hash") @db.VarChar(255)
  role         String       @default("admin") @db.VarChar(50)
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamp(6)
  branch       Branch?      @relation(fields: [branchId], references: [id])
  sessions     POSSession[]
  orders       Order[]

  @@map("users")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(120)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  products  Product[]

  @@map("categories")
}

model Product {
  id            Int              @id @default(autoincrement())
  categoryId    Int              @map("category_id")
  name          String           @db.VarChar(120)
  description   String           @default("")
  basePrice     Decimal          @map("base_price") @db.Decimal(10, 2)
  unit          String           @default("unit") @db.VarChar(50)
  taxRate       Float            @default(0) @map("tax_rate")
  imageUrl      String?          @map("image_url") @db.VarChar(500)
  sendToKitchen Boolean          @default(true) @map("send_to_kitchen")
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamp(6)
  category      Category         @relation(fields: [categoryId], references: [id])
  variants      ProductVariant[]
  orderItems    OrderItem[]

  @@index([name])
  @@map("products")
}

model ProductVariant {
  id        Int                 @id @default(autoincrement())
  productId Int                 @map("product_id")
  name      String              @db.VarChar(120)
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamp(6)
  product   Product             @relation(fields: [productId], references: [id])
  values    ProductVariantValue[]

  @@map("product_variants")
}

model ProductVariantValue {
  id         Int            @id @default(autoincrement())
  variantId  Int            @map("variant_id")
  label      String         @db.VarChar(120)
  extraPrice Decimal        @default(0) @map("extra_price") @db.Decimal(10, 2)
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamp(6)
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@map("product_variant_values")
}

model PaymentMethod {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(120)
  type       String    @db.VarChar(50)
  enabled    Boolean   @default(true)
  configJson Json      @default("{}") @map("config_json")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  payments   Payment[]

  @@map("payment_methods")
}

model Floor {
  id        Int               @id @default(autoincrement())
  branchId  Int?              @map("branch_id")
  name      String            @db.VarChar(120)
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime          @updatedAt @map("updated_at") @db.Timestamp(6)
  branch    Branch?           @relation(fields: [branchId], references: [id])
  tables    RestaurantTable[]

  @@unique([branchId, name], map: "uq_floors_branch_name")
  @@map("floors")
}

model RestaurantTable {
  id          Int              @id @default(autoincrement())
  branchId     Int?             @map("branch_id")
  floorId     Int              @map("floor_id")
  tableNumber String           @map("table_number") @db.VarChar(50)
  seats       Int              @default(2)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamp(6)
  branch      Branch?          @relation(fields: [branchId], references: [id])
  floor       Floor            @relation(fields: [floorId], references: [id])
  orders      Order[]
  tokens      SelfOrderToken[]

  @@unique([branchId, tableNumber], map: "uq_tables_branch_number")
  @@map("restaurant_tables")
}

model POSTerminal {
  id        Int          @id @default(autoincrement())
  branchId  Int?         @map("branch_id")
  name      String       @db.VarChar(120)
  location  String       @default("Main Hall") @db.VarChar(120)
  active    Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamp(6)
  branch    Branch?      @relation(fields: [branchId], references: [id])
  sessions  POSSession[]

  @@unique([branchId, name], map: "uq_terminals_branch_name")
  @@map("pos_terminals")
}

model POSSession {
  id            Int         @id @default(autoincrement())
  branchId      Int?        @map("branch_id")
  terminalId    Int         @map("terminal_id")
  responsibleId Int         @map("responsible_id")
  status        String      @default("open") @db.VarChar(50)
  openingAmount Decimal     @default(0) @map("opening_amount") @db.Decimal(10, 2)
  closingAmount Decimal     @default(0) @map("closing_amount") @db.Decimal(10, 2)
  openedAt      DateTime    @default(now()) @map("opened_at") @db.Timestamp(6)
  closedAt      DateTime?   @map("closed_at") @db.Timestamp(6)
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamp(6)
  branch        Branch?     @relation(fields: [branchId], references: [id])
  terminal      POSTerminal @relation(fields: [terminalId], references: [id])
  responsible   User        @relation(fields: [responsibleId], references: [id])
  orders        Order[]
  tokens        SelfOrderToken[]

  @@map("pos_sessions")
}

model Order {
  id            Int              @id @default(autoincrement())
  branchId      Int?             @map("branch_id")
  orderNumber   String           @unique @map("order_number") @db.VarChar(50)
  sessionId     Int              @map("session_id")
  tableId       Int?             @map("table_id")
  responsibleId Int              @map("responsible_id")
  orderType     String           @default("pos") @map("order_type") @db.VarChar(50)
  status        String           @default("draft") @db.VarChar(50)
  kitchenStatus String           @default("pending") @map("kitchen_status") @db.VarChar(50)
  paymentStatus String           @default("unpaid") @map("payment_status") @db.VarChar(50)
  notes         String           @default("")
  subtotal      Decimal          @default(0) @db.Decimal(10, 2)
  taxTotal      Decimal          @default(0) @map("tax_total") @db.Decimal(10, 2)
  grandTotal    Decimal          @default(0) @map("grand_total") @db.Decimal(10, 2)
  paidAt        DateTime?        @map("paid_at") @db.Timestamp(6)
  closedAt      DateTime?        @map("closed_at") @db.Timestamp(6)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamp(6)
  branch        Branch?          @relation(fields: [branchId], references: [id])
  session       POSSession       @relation(fields: [sessionId], references: [id])
  table         RestaurantTable? @relation(fields: [tableId], references: [id])
  responsible   User             @relation(fields: [responsibleId], references: [id])
  items         OrderItem[]
  payments      Payment[]

  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id           Int      @id @default(autoincrement())
  orderId      Int      @map("order_id")
  productId    Int      @map("product_id")
  productName  String   @map("product_name") @db.VarChar(120)
  quantity     Int      @default(1)
  unitPrice    Decimal  @map("unit_price") @db.Decimal(10, 2)
  taxRate      Float    @default(0) @map("tax_rate")
  totalPrice   Decimal  @map("total_price") @db.Decimal(10, 2)
  kitchenDone  Boolean  @default(false) @map("kitchen_done")
  variantLabel String?  @map("variant_label") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  order        Order    @relation(fields: [orderId], references: [id])
  product      Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id              Int           @id @default(autoincrement())
  orderId         Int           @map("order_id")
  paymentMethodId Int           @map("payment_method_id")
  amount          Decimal       @db.Decimal(10, 2)
  paymentStatus   String        @default("confirmed") @map("payment_status") @db.VarChar(50)
  transactionRef  String?       @map("transaction_ref") @db.VarChar(120)
  reference       String?       @db.VarChar(120)
  paidAt          DateTime?     @map("paid_at") @db.Timestamp(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)
  order           Order         @relation(fields: [orderId], references: [id])
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@map("payments")
}

model SelfOrderToken {
  id        Int             @id @default(autoincrement())
  branchId  Int?            @map("branch_id")
  token     String          @unique @db.VarChar(64)
  tableId   Int             @map("table_id")
  sessionId Int             @map("session_id")
  active    Boolean         @default(true)
  expiresAt DateTime?       @map("expires_at") @db.Timestamp(6)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)
  branch    Branch?         @relation(fields: [branchId], references: [id])
  table     RestaurantTable @relation(fields: [tableId], references: [id])
  session   POSSession      @relation(fields: [sessionId], references: [id])

  @@map("self_order_tokens")
}
